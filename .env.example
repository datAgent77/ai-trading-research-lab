# Required
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
# Optional: second IBKR API session id for Telegram reads (defaults to IBKR_CLIENT_ID + 1)
TELEGRAM_IBKR_CLIENT_ID=
# Optional: explicit Telegram chat/user ids for scheduled reports (comma-separated); defaults to TELEGRAM_ALLOWED_USER_IDS
TELEGRAM_REPORT_CHAT_IDS=
# Live paper loop: notify same recipients on intents / submissions (off by default)
TELEGRAM_LIVE_NOTIFY_ENABLED=false
# If Bot API calls time out, increase (seconds). Optional HTTP proxy for restricted networks.
TELEGRAM_HTTP_TIMEOUT_SECONDS=30
TELEGRAM_PROXY_URL=

# Scheduled Claude reports (scripts/run_scheduled_reports.py)
REPORTS_SCHEDULE_ENABLED=true
REPORT_TIMEZONE=America/New_York
REPORT_DAILY_CRONTAB=5 17 * * mon-fri
REPORT_WEEKLY_CRONTAB=35 17 * * fri

# IBKR (DU… required for paper trading / Telegram IBKR commands; optional for backtests-only)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=42
IBKR_ACCOUNT=DU1234567

# Risk
MAX_DAILY_DRAWDOWN_PCT=-3.0
MAX_POSITION_PCT_NAV=5.0
TRADING_START_NY=09:30
TRADING_END_NY=16:00

# Data
DATA_PROVIDER=yfinance
POLYGON_API_KEY=
DATA_CACHE_DIR=./data/cache

# Database
DATABASE_URL=sqlite:///./trading_lab.db
